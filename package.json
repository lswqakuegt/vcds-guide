{
  "name": "vcds-guide-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "gen:icons": "node scripts/gen-icons.mjs",
    "gen:data": "node scripts/build-datapack.mjs",
    "validate:data": "node scripts/build-datapack.mjs --check",
    "dev": "npm run gen:data && vite",
    "build": "npm run gen:icons && npm run gen:data && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "pngjs": "^7.0.0",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.6"
  }
}
